{
  "name": "flutter-ssl-bypass",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Frida agent that bypasses TLS pinning in arm64 Android Flutter apps.",
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check && bash tools/lint-pointer-arith.sh",
    "lint:pointer-arith": "bash tools/lint-pointer-arith.sh",
    "format": "biome format --write",
    "build": "mkdir -p dist && frida-compile src/main.ts -o dist/flutter-ssl-bypass.js -c",
    "build:dev": "mkdir -p dist && frida-compile src/main.ts -o dist/flutter-ssl-bypass.js",
    "watch": "mkdir -p dist && frida-compile src/main.ts -o dist/flutter-ssl-bypass.js -w",
    "verify:smoke": "bun run scripts/check-smoke-build.ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/frida-gum": "19.0.2",
    "@types/node": "^25.6.0",
    "frida-compile": "19.0.5",
    "typescript": "~5.9.0"
  },
  "trustedDependencies": [
    "frida"
  ]
}
